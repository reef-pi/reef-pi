{
  "name": "reef-pi",
  "version": "1.0.0",
  "private": true,
  "description": "A Raspberry Pi based reeftank automation system",
  "dependencies": {
    "@babel/core": "7.28.4",
    "@babel/plugin-transform-modules-commonjs": "7.18.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "7.24.7",
    "@babel/preset-react": "7.28.5",
    "@redocly/cli": "^2.2.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "autoprefixer": "10.5.0",
    "babel-jest": "30.3.0",
    "babel-loader": "9.2.1",
    "bootstrap": "4.6.2",
    "classnames": "2.5.1",
    "clean-webpack-plugin": "4.0.0",
    "cross-env": "7.0.2",
    "css-loader": "6.8.1",
    "csv-parse": "^5.6.0",
    "csv-stringify": "6.5.2",
    "eslint": "9.26.0",
    "eslint-plugin-react": "7.33.2",
    "fetch-mock": "9.11.0",
    "form-data": "^4.0.1",
    "formik": "2.4.6",
    "html-webpack-plugin": "5.6.7",
    "humanize-duration": "^3.31.0",
    "i18next": "25.5.3",
    "i18next-browser-languagedetector": "8.2.1",
    "isomorphic-fetch": "3.0.0",
    "jest": "30.2.0",
    "jest-date-mock": "1.0.8",
    "jest-environment-jsdom": "30.3.0",
    "jquery": "^3.6.1",
    "json-loader": "0.5.7",
    "lodash.debounce": "4.0.8",
    "lodash.mapvalues": "4.6.0",
    "marked": "^13.0.1",
    "mini-css-extract-plugin": "2.7.6",
    "popper.js": "^1.16.1",
    "postcss": "^8.5.13",
    "postcss-loader": "8.1.1",
    "precss": "4.0.0",
    "prop-types": "15.8.1",
    "react": "19.2.5",
    "react-color": "2.19.3",
    "react-datepicker": "^7.6.0",
    "react-dom": "19.2.5",
    "react-i18next": "12.0.0",
    "react-icons": "5.5.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.2",
    "react-toggle-switch": "3.0.4",
    "recharts": "^2.15.4",
    "redoc-cli": "^0.13.21",
    "redux": "^5.0.1",
    "redux-mock-store": "1.5.5",
    "redux-thunk": "3.1.0",
    "sass": "^1.62.1",
    "sass-lint": "1.13.1",
    "sass-loader": "13.3.2",
    "standard": "17.1.2",
    "style-loader": "3.3.3",
    "webpack": "5.104.1",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "5.2.2",
    "yup": "0.32.11"
  },
  "scripts": {
    "translations:sync": "node ./build/translations/csv-sync.js sync",
    "translations:chk": "node ./build/translations/csv-sync.js chk",
    "build": "webpack",
    "ui": "webpack --mode=production",
    "ui-dev": "webpack --watch --mode=development",
    "js-lint": "standard \"front-end/src/**/*.{js,jsx}\"",
    "standard": "standard --fix \"front-end/src/**/*.{js,jsx}\"",
    "jest": "cross-env NODE_ENV=testing jest --env=jsdom",
    "jest-update-snapshot": "cross-env NODE_ENV=testing jest --coverage --all --updateSnapshot --env=jsdom",
    "test": "cross-env NODE_ENV=testing jest --all --updateSnapshot --no-cache --coverage --env=jsdom",
    "sass-lint": "sass-lint 'front-end/assets/sass/**/*.scss' --verbose",
    "smoke": "playwright test",
    "pw-smoke": "playwright test",
    "pw-smoke:headed": "playwright test --headed"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reef-pi/reef-pi.git"
  },
  "author": {
    "name": "Ranjib Dey",
    "email": "ranjib@linux.com",
    "url": "http://ranjib.com/"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/reef-pi/reef-pi/issues"
  },
  "homepage": "https://reef-pi.github.io",
  "sasslintConfig": "sass-lint.yml",
  "standard": {
    "globals": [
      "describe",
      "it",
      "fetch",
      "expect",
      "Headers",
      "afterEach",
      "jest",
      "beforeEach"
    ],
    "ignore": [
      "*.test.js",
      "**/__snapshots__",
      "**/__snapshots__/**"
    ]
  },
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/front-end/test/setup.js"
    ],
    "testMatch": [
      "**/?(*.)+(test).[jt]s?(x)"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/front-end/e2e/"
    ],
    "coveragePathIgnorePatterns": [
      "<rootDir>/build/translations/",
      "<rootDir>/front-end/test/"
    ],
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "transformIgnorePatterns": [],
    "moduleDirectories": [
      "node_modules",
      "front-end/src/",
      "front-end/assets/translations/"
    ],
    "moduleNameMapper": {
      "^redux/actions/(.*)$": "<rootDir>/front-end/src/redux/actions/$1",
      "^redux/store$": "<rootDir>/front-end/src/redux/store.js",
      "\\.(css|less|sass|scss)$": "<rootDir>/front-end/test/jest_config.js",
      "\\.csv$": "<rootDir>/build/translations/loader.js"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
